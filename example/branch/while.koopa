decl @getint(): i32

decl @getch(): i32

decl @getarray(*i32): i32

decl @putint(i32)

decl @putch(i32)

decl @putarray(i32, *i32)

decl @starttime()

decl @stoptime()

fun @main(): i32 {
%entry:
  %0 = alloc i32
  store 0, %0
  jump %1

%1:
  %2 = load %0
  %3 = lt %2, 10
  br %3, %4, %5

%4:
  %6 = load %0
  %7 = add %6, 1
  store %7, %0
  jump %1

%5:
  %8 = load %0
  ret %8
}
