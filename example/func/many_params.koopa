  %7 = alloc i32
  store @a7, %7
  %8 = load %0
  %9 = load %1
  %10 = add %8, %9
  %11 = load %2
  %12 = add %10, %11
  %13 = load %3
  %14 = add %12, %13
  %15 = load %4
  %16 = add %14, %15
  %17 = load %5
  %18 = add %16, %17
  %19 = load %6
  %20 = add %18, %19
  %21 = load %7
  %22 = add %20, %21
  ret %22
}

