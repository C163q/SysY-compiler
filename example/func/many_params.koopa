fun @sum(@a0: i32, @a1: i32, @a2: i32, @a3: i32, @a4: i32, @a5: i32, @a6: i32, @a7: i32): i32 {
%entry:
  %0 = alloc i32
  store @a0, %0
  %1 = alloc i32
  store @a1, %1
